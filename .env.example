# Salesforce AI Search - Environment Variables Template
# **Feature: zero-config-production, Task 28.2**
#
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!
#
# Usage:
#   cp .env.example .env
#   # Edit .env with your values
#   source .env  # or use python-dotenv
#
# For CI/CD, set these as secrets in your pipeline configuration.

# =============================================================================
# API Configuration
# =============================================================================

# Lambda Function URL for the Answer endpoint
SALESFORCE_AI_SEARCH_LAMBDA_URL=https://your-lambda-url.lambda-url.us-west-2.on.aws

# API Key for authenticating requests (retrieve from AWS Secrets Manager or API Gateway)
# SECURITY: Never commit actual API keys to version control
SALESFORCE_AI_SEARCH_API_KEY=your-api-key-here

# Bedrock Knowledge Base ID
SALESFORCE_AI_SEARCH_KNOWLEDGE_BASE_ID=your-knowledge-base-id

# =============================================================================
# AWS Configuration
# =============================================================================

# AWS Region for API calls
AWS_REGION=us-west-2

# AWS Profile (optional, for local development)
# AWS_PROFILE=your-profile-name

# =============================================================================
# Salesforce Configuration
# =============================================================================

# Test User ID for running automated tests
SALESFORCE_AI_SEARCH_TEST_USER_ID=005xxxxxxxxxxxxxxxxx

# Salesforce Instance URL (for schema discovery and API calls)
SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com

# =============================================================================
# Testing Configuration
# =============================================================================

# Log level for test output (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Test timeout in seconds
TEST_TIMEOUT=30

# =============================================================================
# Development Configuration
# =============================================================================

# Enable debug mode for verbose output
DEBUG=false

# Skip SSL verification (only for local development with self-signed certs)
# SKIP_SSL_VERIFY=false
