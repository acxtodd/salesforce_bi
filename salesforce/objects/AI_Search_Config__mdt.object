<?xml version="1.0" encoding="UTF-8"?>
<CustomObject xmlns="http://soap.sforce.com/2006/04/metadata">
    <label>AI Search Config</label>
    <pluralLabel>AI Search Configs</pluralLabel>
    <visibility>Public</visibility>
    <fields>
        <fullName>Ingest_Endpoint__c</fullName>
        <label>Ingest Endpoint</label>
        <type>Url</type>
        <required>true</required>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>API_Key__c</fullName>
        <label>API Key</label>
        <type>Text</type>
        <length>255</length>
        <required>true</required>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>Batch_Size__c</fullName>
        <label>Batch Size</label>
        <type>Number</type>
        <precision>4</precision>
        <scale>0</scale>
        <required>false</required>
        <defaultValue>200</defaultValue>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>Hours_Back__c</fullName>
        <label>Hours Back</label>
        <type>Number</type>
        <precision>3</precision>
        <scale>0</scale>
        <required>false</required>
        <defaultValue>24</defaultValue>
        <externalId>false</externalId>
    </fields>
    <fields>
        <fullName>Enabled__c</fullName>
        <label>Enabled</label>
        <type>Checkbox</type>
        <required>false</required>
        <defaultValue>true</defaultValue>
        <externalId>false</externalId>
    </fields>
</CustomObject>
