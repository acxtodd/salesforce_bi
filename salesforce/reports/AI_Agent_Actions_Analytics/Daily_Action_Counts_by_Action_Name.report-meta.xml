<?xml version="1.0" encoding="UTF-8"?>
<Report xmlns="http://soap.sforce.com/2006/04/metadata">
    <aggregates>
        <calculatedFormula>RowCount</calculatedFormula>
        <datatype>number</datatype>
        <description>Total number of actions executed</description>
        <developerName>FORMULA1</developerName>
        <isActive>true</isActive>
        <isCrossBlock>false</isCrossBlock>
        <masterLabel>Total Actions</masterLabel>
        <scale>0</scale>
    </aggregates>
    <aggregates>
        <calculatedFormula>IF(AI_Action_Audit__c.Success__c:SUM &gt; 0, (AI_Action_Audit__c.Success__c:SUM / RowCount) * 100, 0)</calculatedFormula>
        <datatype>percent</datatype>
        <description>Success rate percentage</description>
        <developerName>FORMULA2</developerName>
        <isActive>true</isActive>
        <isCrossBlock>false</isCrossBlock>
        <masterLabel>Success Rate</masterLabel>
        <scale>2</scale>
    </aggregates>

    <columns>
        <field>AI_Action_Audit__c.UserId__c</field>
    </columns>
    <columns>
        <field>AI_Action_Audit__c.Success__c</field>
    </columns>
    <columns>
        <field>AI_Action_Audit__c.LatencyMs__c</field>
    </columns>
    <description>Daily and weekly action counts grouped by action name</description>
    <format>Summary</format>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>CUST_CREATED_DATE</field>
        <sortOrder>Desc</sortOrder>
    </groupingsDown>
    <groupingsDown>
        <dateGranularity>Day</dateGranularity>
        <field>AI_Action_Audit__c.ActionName__c</field>
        <sortOrder>Asc</sortOrder>
    </groupingsDown>
    <name>Daily Action Counts by Action Name</name>
    <params>
        <name>co</name>
        <value>1</value>
    </params>
    <reportType>CustomEntity$AI_Action_Audit__c</reportType>
    <scope>organization</scope>
    <showDetails>true</showDetails>
    <showGrandTotal>true</showGrandTotal>
    <showSubTotals>true</showSubTotals>
    <timeFrameFilter>
        <dateColumn>CUST_CREATED_DATE</dateColumn>
        <interval>INTERVAL_LAST7</interval>
    </timeFrameFilter>
</Report>
