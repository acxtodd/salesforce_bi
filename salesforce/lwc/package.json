{
  "name": "salesforce-lwc-tests",
  "version": "1.0.0",
  "description": "Jest tests for Salesforce Lightning Web Components",
  "scripts": {
    "test": "cd .. && jest --config=lwc/jest.config.js --silent",
    "test:watch": "cd .. && jest --config=lwc/jest.config.js --watch",
    "test:coverage": "cd .. && jest --config=lwc/jest.config.js --coverage --silent",
    "test:debug": "cd .. && node --inspect-brk node_modules/.bin/jest --config=lwc/jest.config.js --runInBand"
  },
  "devDependencies": {
    "@salesforce/sfdx-lwc-jest": "^3.0.0",
    "jest": "^29.0.0"
  }
}
